NEXT_PUBLIC_API_URL=http://localhost:5000/api

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_secret

# Google OAuth credentials (from Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Must match the backend's INTERNAL_API_SECRET. Server-side only, never exposed to the browser.
INTERNAL_API_SECRET=replace_with_a_long_random_secret
