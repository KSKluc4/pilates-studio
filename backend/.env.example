NODE_ENV=development
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/pilates-studio

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000

# Shared secret used by the frontend's NextAuth Google callback to call POST /api/auth/google.
# Must match the INTERNAL_API_SECRET configured in the frontend's environment.
INTERNAL_API_SECRET=replace_with_a_long_random_secret

# Resend (email service for password recovery) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# From address: use a verified domain in production; onboarding@resend.dev works only for testing
RESEND_FROM_EMAIL=onboarding@resend.dev

# Public URL of the frontend (used to build password-reset links)
FRONTEND_URL=http://localhost:3000
